source "https://rubygems.org"

# Pinned 2026-06-09: fastlane 2.236.0 (released after the 6/6 good builds)
# broke the TestFlight upload — pilot/altool fails with "file isn't in the
# correct format (259)" on an IPA that built and signed fine. 2.235.0 is the
# last known-good. Same root cause as the multi_json incident below: no
# committed Gemfile.lock means every CI run re-resolves gems fresh.
# Unpin only after verifying a newer fastlane uploads successfully.
gem "fastlane", "2.235.0"

# Pinned explicitly to fix intermittent CI failure: "multi_json is not part of
# the bundle" (Gem::LoadError). Without a committed Gemfile.lock, each CI run
# re-resolves Fastlane's transitive gems fresh, and some resolutions drop
# multi_json from the runtime bundle. Declaring it directly guarantees it's
# always bundled. (Durable fix remains committing a Gemfile.lock — see
# dependency-watch.md outstanding items.)
gem "multi_json"

# GroundLog environment variables — copy to .env (gitignored) for local dev.
# In CI, these are injected from GitHub Actions secrets at build time.
#
# See: groundlog/wiki/dependency-watch.md §1 for full Sentry setup context.

# ─── Runtime (baked into the JS bundle at build time) ──────────────────────
# Public DSN — designed to be embedded in client code. Without it, Sentry
# init is a no-op (zero events sent) so local dev / forks don't pollute
# the production Sentry project.
VITE_SENTRY_DSN=

# ─── Build-time only (used by @sentry/vite-plugin for source map upload) ───
# These are NOT baked into the bundle — only read by the Vite build process.
# Auth token is private; org/project slugs are not secret but kept here for
# CI consistency. Without SENTRY_AUTH_TOKEN, the plugin gracefully skips
# upload (logs a warning). Useful for local builds that don't need to ship
# maps to Sentry.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
